# Auto-Sync INDEX - DO NOT EDIT MANUALLY
# Format: {"p":"path","t":"type","m":mtime,"h":"hash","pr":"protocol","v":"version","u":"updated","s":"status"}
#
# Fields:
#   p  - Relative path from project root
#   t  - Type: skill, agent, doc, rule
#   m  - File mtime as Unix epoch (seconds)
#   h  - Content hash (SHA256[:8])
#   pr - Protocol name (default, custom-name)
#   v  - Document version from frontmatter
#   u  - Last sync timestamp (ISO8601)
#   s  - Status: ok, stale, error
#
# Types:
#   skill - Has name: focus-task:* or name: <project>:* in frontmatter
#   agent - Has tools: AND model: in frontmatter
#   rule  - Path contains /rules/
#   doc   - Default (any markdown with auto-sync tag)
#
# Status:
#   ok    - Synced within threshold
#   stale - Older than threshold (default: 7 days)
#   error - Sync failed, needs attention
#
# Stale threshold: 7 days (configurable in focus-task.config.json)
#
