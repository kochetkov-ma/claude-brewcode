{
  "logging": {
    "level": "info"
  },
  "agents": {
    "system": [
      "bd-auto-sync-processor",
      "Explore", "Plan", "Bash", "general-purpose",
      "claude-code-guide", "skill-creator", "agent-creator",
      "text-optimizer", "statusline-setup"
    ]
  },
  "constraints": {
    "enabled": true
  },
  "autoSync": {
    "intervalDays": 7,
    "retention": {
      "maxEntries": 200
    },
    "optimize": false,
    "parallelAgents": 5
  }
}
