:80 {
    redir / /getting-started/ permanent

    root * /srv
    encode zstd gzip
    file_server

    header /_astro/* Cache-Control "public, max-age=31536000, immutable"
    header * {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    handle_errors {
        rewrite * /404.html
        file_server
    }
}
