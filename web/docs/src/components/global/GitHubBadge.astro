---
import { GITHUB_URL, GITHUB_REPO } from '../../utils/github';
---

<a
  href={GITHUB_URL}
  target="_blank"
  rel="noopener noreferrer"
  class="hidden sm:inline-flex items-center gap-1.5 text-xs bg-base-300 hover:bg-base-100 transition-colors rounded-full px-3 py-1"
  id="github-badge"
  aria-label="GitHub repository"
>
  <span id="gh-stars" class="hidden inline-flex items-center gap-1">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 text-brand-300">
      <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.434c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.434 2.082-5.005Z" clip-rule="evenodd" />
    </svg>
    <span id="gh-stars-count" class="font-semibold"></span>
    <span class="text-base-content/50">&middot;</span>
  </span>
  <span id="gh-version" class="text-base-content/60"></span>
</a>

<a
  href={GITHUB_URL}
  target="_blank"
  rel="noopener noreferrer"
  class="inline-flex sm:hidden items-center gap-1 text-xs px-2 py-1 rounded-full hover:bg-base-300 transition-colors"
  id="github-badge-mobile"
  aria-label="GitHub repository"
>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-base-content">
    <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
  </svg>
  <span id="gh-stars-count-mobile" class="font-semibold hidden"></span>
</a>

<script define:vars={{ repo: GITHUB_REPO }}>
  fetch(`https://api.github.com/repos/${repo}`)
    .then(r => r.ok ? r.json() : null)
    .then(data => {
      if (!data || !(data.stargazers_count > 0)) return;
      const count = data.stargazers_count + '+';
      document.getElementById('gh-stars-count').textContent = count;
      document.getElementById('gh-stars').classList.remove('hidden');
      const mobileCount = document.getElementById('gh-stars-count-mobile');
      mobileCount.textContent = count;
      mobileCount.classList.remove('hidden');
    })
    .catch(() => {});

  fetch(`https://api.github.com/repos/${repo}/releases/latest`)
    .then(r => r.ok ? r.json() : null)
    .then(data => {
      if (data?.tag_name) {
        document.getElementById('gh-version').textContent = data.tag_name;
      }
    })
    .catch(() => {});
</script>
