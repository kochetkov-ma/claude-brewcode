<div class="not-prose my-6">
  <ol class="steps-timeline flex flex-col gap-0">
    <slot />
  </ol>
</div>

<style>
  /* Scoped to DIRECT children only so nested <ul><li> inside a step's body
     do not get counter-increment, a circle marker, or the grid layout.
     Previously `.steps-timeline :global(li)` matched ANY descendant <li>,
     which broke nested lists (file lists, bullet lists) by renumbering them
     as continuation steps. See .claude/rules/astro-avoid.md. */
  .steps-timeline {
    counter-reset: step-counter;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  :global(.steps-timeline > li) {
    counter-increment: step-counter;
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: 0 0.75rem;
    padding-bottom: 1.5rem;
    position: relative;
    list-style: none;
  }

  :global(.steps-timeline > li)::before {
    content: counter(step-counter);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 9999px;
    background-color: oklch(var(--p));
    color: oklch(var(--pc));
    font-weight: 700;
    font-size: 0.875rem;
    grid-column: 1;
    grid-row: 1;
    position: relative;
    z-index: 1;
    flex-shrink: 0;
  }

  :global(.steps-timeline > li)::after {
    content: '';
    position: absolute;
    left: 1.125rem;
    top: 2.5rem;
    bottom: 0;
    width: 0.25rem;
    border-radius: 0.125rem;
    background-color: oklch(var(--p) / 0.3);
  }

  :global(.steps-timeline > li:last-child)::after {
    display: none;
  }

  :global(.steps-timeline > li:last-child) {
    padding-bottom: 0;
  }

  /* Only style the immediate title/paragraph of a step; nested children
     keep their normal prose styles. */
  :global(.steps-timeline > li > div > strong:first-child),
  :global(.steps-timeline > li > strong:first-child) {
    grid-column: 2;
    grid-row: 1;
    align-self: center;
    font-size: 1.05rem;
    color: oklch(var(--bc));
  }

  :global(.steps-timeline > li > div),
  :global(.steps-timeline > li > p) {
    grid-column: 2;
    color: oklch(var(--bc) / 0.9);
    font-size: 0.925rem;
    line-height: 1.6;
  }

  /* Restore default list markers for nested lists inside a step body. */
  :global(.steps-timeline > li ul) {
    list-style: disc;
    padding-left: 1.25rem;
    margin: 0.5rem 0;
  }
  :global(.steps-timeline > li ol) {
    list-style: decimal;
    padding-left: 1.25rem;
    margin: 0.5rem 0;
  }
  :global(.steps-timeline > li ul li),
  :global(.steps-timeline > li ol li) {
    display: list-item;
    padding: 0;
    margin: 0.15rem 0;
  }
</style>
