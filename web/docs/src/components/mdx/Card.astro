---
interface Props {
  title: string;
  icon?: string;
  href?: string;
}

const iconMap: Record<string, string> = {
  book: '\u{1F4D6}',
  brain: '\u{1F9E0}',
  building: '\u{1F3DB}',
  chart: '\u{1F4CA}',
  check: '\u{2705}',
  clipboard: '\u{1F4CB}',
  code: '\u{1F4BB}',
  document: '\u{1F4C4}',
  external: '\u{1F517}',
  eye: '\u{1F441}',
  file: '\u{1F4C2}',
  flask: '\u{1F9EA}',
  'forward-slash': '\u{26A1}',
  group: '\u{1F465}',
  infinity: '\u{267E}\uFE0F',
  link: '\u{1F517}',
  list: '\u{1F4DD}',
  lock: '\u{1F512}',
  pencil: '\u{270F}\uFE0F',
  people: '\u{1F46B}',
  play: '\u{25B6}\uFE0F',
  puzzle: '\u{1F9E9}',
  search: '\u{1F50D}',
  settings: '\u{2699}\uFE0F',
  shield: '\u{1F6E1}\uFE0F',
  sparkle: '\u{2728}',
  star: '\u{2B50}',
  sync: '\u{1F504}',
  terminal: '\u{1F4DF}',
  trash: '\u{1F5D1}\uFE0F',
  user: '\u{1F464}',
  users: '\u{1F465}',
  wrench: '\u{1F527}',
  heart: '\u{2764}\uFE0F',
  money: '\u{1F4B0}',
  library: '\u{1F4DA}',
  fire: '\u{1F525}',
  handshake: '\u{1F91D}',
  rocket: '\u{1F680}',
  package: '\u{1F4E6}',
  image: '\u{1F5BC}\uFE0F',
  plus: '\u{2795}',
  warning: '\u{26A0}\uFE0F',
  bell: '\u{1F514}',
  bolt: '\u{26A1}',
  bug: '\u{1F41B}',
  calendar: '\u{1F4C5}',
  clock: '\u{23F0}',
  cloud: '\u{2601}\uFE0F',
  database: '\u{1F4BE}',
  gear: '\u{2699}\uFE0F',
  globe: '\u{1F310}',
  graph: '\u{1F4C8}',
  hammer: '\u{1F528}',
  key: '\u{1F511}',
  label: '\u{1F3F7}\uFE0F',
  magic: '\u{2728}',
  megaphone: '\u{1F4E2}',
  note: '\u{1F4DD}',
  phone: '\u{1F4DE}',
  pin: '\u{1F4CC}',
  refresh: '\u{1F504}',
  robot: '\u{1F916}',
  scroll: '\u{1F4DC}',
  shieldCheck: '\u{1F6E1}\uFE0F',
  ship: '\u{1F6A2}',
  target: '\u{1F3AF}',
  test: '\u{1F9EA}',
  tool: '\u{1F6E0}\uFE0F',
  trophy: '\u{1F3C6}',
  zap: '\u{26A1}',
};

const { title, icon: rawIcon, href } = Astro.props;
// Unknown icons fall back to a random whitelist icon + console.warn, so pages
// never leak raw icon names as text. Add proper names to iconMap when you see
// the warning in build logs or the browser console.
// See .claude/rules/astro-avoid.md (icon whitelist).
const iconKeys = Object.keys(iconMap);
let icon: string;
if (!rawIcon) {
  icon = '';
} else if (iconMap[rawIcon]) {
  icon = iconMap[rawIcon];
} else {
  console.warn(`[Card] Unknown icon "${rawIcon}" on card "${title}" — add it to iconMap in Card.astro. Rendering fallback icon.`);
  // Deterministic fallback: hash the unknown name so the same bad name always
  // gets the same fallback icon (less jarring than pure random across rebuilds).
  let hash = 0;
  for (const ch of rawIcon) hash = (hash * 31 + ch.charCodeAt(0)) >>> 0;
  icon = iconMap[iconKeys[hash % iconKeys.length]];
}
---

<div
  class:list={[
    'not-prose card bg-base-200 border border-base-300 p-5 relative',
    href && 'hover:border-primary/50 hover:shadow-lg hover:shadow-primary/5 transition-all cursor-pointer',
  ]}
>
  {href && (
    <a href={href} class="absolute inset-0 z-0 rounded-[inherit]" tabindex="-1" aria-hidden="true"></a>
  )}
  <div class:list={['flex items-start gap-3', href && 'relative z-[1]']}>
    {icon && <span class="text-2xl shrink-0">{icon}</span>}
    <div>
      <h3 class="font-headline font-semibold text-base-content mb-1">
        {href ? <a href={href}>{title}</a> : title}
      </h3>
      <div class="text-sm text-base-content/70">
        <slot />
      </div>
    </div>
  </div>
</div>
