---
interface Props {
  title: string;
  id?: string;
  open?: boolean;
}

const { title, id, open = false } = Astro.props;
---

<details class="spoiler not-prose my-3" id={id} open={open}>
  <summary class="spoiler-summary">
    <span class="spoiler-icon" aria-hidden="true">▶</span>
    <span class="spoiler-title">{title}</span>
  </summary>
  <div class="spoiler-content prose">
    <slot />
  </div>
</details>

<script>
  function openSpoilerForHash() {
    const hash = window.location.hash.slice(1);
    if (!hash) return;
    const target = document.getElementById(hash);
    if (target instanceof HTMLDetailsElement && target.classList.contains('spoiler')) {
      if (!target.open) target.open = true;
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }

  function initSpoilerHashHandling() {
    if ((document as any).__spoilerHashInit) return;
    (document as any).__spoilerHashInit = true;
    openSpoilerForHash();
    window.addEventListener('hashchange', openSpoilerForHash);
    document.addEventListener('click', (e) => {
      const link = (e.target as HTMLElement)?.closest('a[href^="#"]') as HTMLAnchorElement | null;
      if (!link) return;
      setTimeout(openSpoilerForHash, 0);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSpoilerHashHandling);
  } else {
    initSpoilerHashHandling();
  }
  document.addEventListener('astro:page-load', initSpoilerHashHandling);
</script>

<style>
  .spoiler {
    border: 1px solid #3D3826;
    border-radius: 0.5rem;
    background-color: rgba(235, 187, 64, 0.04);
    overflow: hidden;
  }

  .spoiler[open] {
    background-color: rgba(235, 187, 64, 0.07);
  }

  .spoiler-summary {
    cursor: pointer;
    padding: 0.85rem 1.1rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    list-style: none;
    user-select: none;
    font-weight: 600;
    color: #EBBB40;
    transition: background-color 0.15s ease;
  }

  .spoiler-summary::-webkit-details-marker {
    display: none;
  }

  .spoiler-summary:hover {
    background-color: rgba(235, 187, 64, 0.1);
  }

  .spoiler-summary:focus-visible {
    outline: 2px solid #EBBB40;
    outline-offset: -2px;
  }

  .spoiler-icon {
    display: inline-block;
    transition: transform 0.2s ease;
    font-size: 0.75rem;
    color: #EBBB40;
    flex-shrink: 0;
  }

  .spoiler[open] .spoiler-icon {
    transform: rotate(90deg);
  }

  .spoiler-title {
    flex: 1;
    color: #D6D3D1;
  }

  .spoiler-content {
    padding: 0.5rem 1.1rem 1.1rem 1.1rem;
    border-top: 1px solid #3D3826;
    margin-top: 0;
  }

  .spoiler-content > :first-child {
    margin-top: 0.75rem;
  }

  .spoiler-content > :last-child {
    margin-bottom: 0;
  }
</style>
