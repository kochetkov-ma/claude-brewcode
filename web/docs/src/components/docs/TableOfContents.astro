---
interface Props {
  headings?: { depth: number; slug: string; text: string }[];
}

const { headings = [] } = Astro.props;
const filtered = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{filtered.length > 0 && (
  <nav class="sticky top-20 py-8" aria-label="Table of contents">
    <h4 class="text-xs font-headline uppercase tracking-wider text-base-content/50 mb-3">On this page</h4>
    <ul id="toc-list" class="space-y-1 text-sm">
      {filtered.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            class:list={[
              'block py-1 transition-colors hover:text-primary',
              heading.depth === 3 ? 'pl-4 text-base-content/50' : 'text-base-content/70',
            ]}
            data-heading={heading.slug}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<script>
  let tocObserver: IntersectionObserver | null = null;

  document.addEventListener('astro:page-load', () => {
    if (tocObserver) tocObserver.disconnect();

    const tocLinks = document.querySelectorAll('#toc-list a[data-heading]');
    if (tocLinks.length === 0) return;

    tocObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            tocLinks.forEach((link) => link.classList.remove('text-primary', '!text-primary'));
            const active = document.querySelector(`#toc-list a[data-heading="${entry.target.id}"]`);
            if (active) {
              active.classList.add('!text-primary');
            }
          }
        });
      },
      { rootMargin: '0px 0px -66% 0px' }
    );

    document.querySelectorAll('article h2[id], article h3[id]').forEach((heading) => {
      tocObserver!.observe(heading);
    });
  });
</script>
